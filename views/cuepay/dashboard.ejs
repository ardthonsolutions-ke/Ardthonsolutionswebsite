<%- include('../layouts/main') %>
<style>
.cuepay-nav { background: linear-gradient(135deg, #0ea5e9, #0284c7); padding: 15px 0; }
.cuepay-nav a { color: white !important; text-decoration: none; font-weight: 500; }
.device-card {
  background: white; border-radius: 15px; padding: 25px;
  box-shadow: 0 5px 20px rgba(0,0,0,0.1); transition: all 0.3s;
  border-left: 4px solid #e5e7eb;
}
.device-card:hover { transform: translateY(-5px); box-shadow: 0 15px 40px rgba(0,0,0,0.15); }
.device-card.online { border-left-color: #10b981; }
.device-card.offline { border-left-color: #ef4444; opacity: 0.7; }
.games-count { font-size: 2.5rem; font-weight: 800; color: #0ea5e9; }
.battery-bar { height: 8px; background: #e5e7eb; border-radius: 4px; overflow: hidden; }
.battery-fill { height: 100%; border-radius: 4px; }
.battery-good { background: #10b981; }
.battery-medium { background: #f59e0b; }
.battery-low { background: #ef4444; }
</style>
</head>
<body>
<nav class="cuepay-nav">
  <div class="container d-flex justify-content-between align-items-center">
    <a href="/cuepay/dashboard"><i class="fas fa-water fa-2x me-2"></i><span class="h4 fw-bold">CuePay</span></a>
    <div>
      <a href="/cuepay/register-device" class="btn btn-light btn-sm me-2 rounded-pill"><i class="fas fa-plus me-1"></i> Add Device</a>
      <a href="/cuepay/logout" class="btn btn-outline-light btn-sm rounded-pill">Logout</a>
    </div>
  </div>
</nav>

<div class="container py-4">
  <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
    <div class="alert alert-success"><%= success_msg %></div>
  <% } %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Your Pool Tables</h2>
    <a href="/cuepay/register-device" class="btn btn-primary rounded-pill" style="background:#0ea5e9;">
      <i class="fas fa-plus me-2"></i> Register New Device
    </a>
  </div>

  <% if (typeof devices === 'undefined' || devices.length === 0) { %>
    <div class="text-center py-5">
      <i class="fas fa-microchip fa-5x text-muted mb-3"></i>
      <h3>No Devices Registered</h3>
      <p class="text-muted">Register your first CuePay device to start monitoring your pool tables</p>
      <a href="/cuepay/register-device" class="btn btn-primary btn-lg rounded-pill mt-3" style="background:#0ea5e9;">
        <i class="fas fa-plus me-2"></i> Register Device
      </a>
    </div>
  <% } else { %>
    <div class="row g-4">
      <% devices.forEach(function(device) { %>
        <div class="col-md-6 col-lg-4">
          <a href="/cuepay/device/<%= device.device_id %>" class="text-decoration-none text-dark">
            <div class="device-card <%= device.is_online ? 'online' : 'offline' %>">
              <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                  <h5 class="mb-1"><%= device.device_name %></h5>
                  <small class="text-muted"><%= device.device_id %></small>
                </div>
                <span class="badge bg-<%= device.is_online ? 'success' : 'danger' %>"><%= device.status %></span>
              </div>
              <div class="row text-center mb-3">
                <div class="col-4"><div class="games-count"><%= device.games_available || 0 %></div><small class="text-muted">Games</small></div>
                <div class="col-4"><div class="h4 fw-bold text-success">Ksh <%= device.today_revenue || 0 %></div><small class="text-muted">Today</small></div>
                <div class="col-4"><div class="h4 fw-bold">Ksh <%= device.game_price %></div><small class="text-muted">Price</small></div>
              </div>
              <div class="mb-2">
                <small>Battery: <%= device.battery_percent %>%</small>
                <div class="battery-bar"><div class="battery-fill <%= device.battery_percent > 50 ? 'battery-good' : device.battery_percent > 20 ? 'battery-medium' : 'battery-low' %>" style="width:<%= device.battery_percent %>%"></div></div>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>
  <% } %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>