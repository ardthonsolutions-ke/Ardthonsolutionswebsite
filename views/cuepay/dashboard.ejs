<%- include('../layouts/main') %>
<style>
.cuepay-nav { background: linear-gradient(135deg, #0ea5e9, #0284c7); padding: 15px 0; }
.cuepay-nav a { color: white !important; text-decoration: none; font-weight: 500; }
.device-card {
  background: white; border-radius: 15px; padding: 25px;
  box-shadow: 0 5px 20px rgba(0,0,0,0.1); transition: all 0.3s;
  border-left: 4px solid #e5e7eb; margin-bottom: 25px;
}
.device-card:hover { transform: translateY(-3px); box-shadow: 0 15px 40px rgba(0,0,0,0.15); }
.device-card.online { border-left-color: #10b981; }
.device-card.offline { border-left-color: #ef4444; opacity: 0.7; }
.stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 12px; margin-bottom: 15px; }
.stat-item { background: #f8fafc; padding: 12px; border-radius: 10px; text-align: center; }
.stat-value { font-size: 1.5rem; font-weight: 800; color: #0ea5e9; }
.stat-label { font-size: 0.7rem; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; }
.stat-value.green { color: #10b981; }
.stat-value.orange { color: #f59e0b; }
.peak-badge { background: #fef3c7; color: #92400e; padding: 3px 10px; border-radius: 15px; font-size: 0.75rem; font-weight: 600; }
.battery-bar { height: 6px; background: #e5e7eb; border-radius: 3px; overflow: hidden; margin-top: 5px; }
.battery-fill { height: 100%; border-radius: 3px; }
.battery-good { background: #10b981; }
.battery-medium { background: #f59e0b; }
.battery-low { background: #ef4444; }
</style>
</head>
<body>
<nav class="cuepay-nav">
  <div class="container d-flex justify-content-between align-items-center">
    <a href="/cuepay/dashboard" class="text-white text-decoration-none">
      <i class="fas fa-water fa-2x me-2"></i><span class="h4 fw-bold">CuePay</span>
    </a>
    <div>
      <span class="text-white me-3 d-none d-md-inline">Welcome, <%= typeof user !== 'undefined' && user ? (user.name || user.email) : 'User' %></span>
      <a href="/cuepay/register-device" class="btn btn-light btn-sm me-2 rounded-pill"><i class="fas fa-plus me-1"></i> Add Device</a>
      <a href="/cuepay/logout" class="btn btn-outline-light btn-sm rounded-pill">Logout</a>
    </div>
  </div>

  <div class="container py-2">
    <div class="d-flex flex-wrap gap-2">
      <a href="/cuepay/dashboard" class="btn btn-sm btn-light rounded-pill active">📊 Dashboard</a>
      <a href="/cuepay/reports/daily" class="btn btn-sm btn-outline-light rounded-pill">📅 Daily Report</a>
      <a href="/cuepay/reports/weekly" class="btn btn-sm btn-outline-light rounded-pill">📈 Weekly</a>
      <a href="/cuepay/reports/monthly" class="btn btn-sm btn-outline-light rounded-pill">📆 Monthly</a>
      <a href="/cuepay/staff" class="btn btn-sm btn-outline-light rounded-pill">👥 Staff</a>
      <a href="/cuepay/alerts" class="btn btn-sm btn-outline-light rounded-pill">🔔 Alerts</a>
    </div>
  </div>
</nav>

<div class="container py-4">
  <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
    <div class="alert alert-success"><%= success_msg %></div>
  <% } %>

  <div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Your Pool Tables</h2>
    <a href="/cuepay/register-device" class="btn btn-primary rounded-pill" style="background:#0ea5e9;">
      <i class="fas fa-plus me-2"></i> Register New Device
    </a>
  </div>

  <% if (typeof devices === 'undefined' || devices.length === 0) { %>
    <div class="text-center py-5">
      <i class="fas fa-microchip fa-5x text-muted mb-3"></i>
      <h3>No Devices Registered</h3>
      <p class="text-muted">Register your first CuePay device to start monitoring your pool tables</p>
      <a href="/cuepay/register-device" class="btn btn-primary btn-lg rounded-pill mt-3" style="background:#0ea5e9;">
        <i class="fas fa-plus me-2"></i> Register Device
      </a>
    </div>
  <% } else { %>
    <% devices.forEach(function(device) { %>
      <a href="/cuepay/device/<%= device.device_id %>" class="text-decoration-none text-dark">
        <div class="device-card <%= device.is_online ? 'online' : 'offline' %>">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <h4 class="mb-1"><%= device.device_name %></h4>
              <small class="text-muted"><%= device.device_id %> • <%= device.location_area || 'No location' %></small>
            </div>
            <div class="text-end">
              <span id="status-<%= device.device_id %>" class="badge bg-<%= device.is_online ? 'success' : 'danger' %> mb-1"><%= device.status %></span><br>
              <small class="text-muted">Ksh <%= device.game_price %>/game</small>
            </div>
          </div>

          <div class="stat-grid">
            <div class="stat-item">
              <div class="stat-value" id="games-<%= device.device_id %>"><%= device.games_available || 0 %></div>
              <div class="stat-label">Games Left</div>
            </div>
            <div class="stat-item">
              <div class="stat-value green" id="revenue-<%= device.device_id %>">Ksh <%= device.today_revenue || 0 %></div>
              <div class="stat-label">Today Revenue</div>
            </div>
            <div class="stat-item">
              <div class="stat-value"><%= device.today_games || 0 %></div>
              <div class="stat-label">Today Games</div>
            </div>
            <div class="stat-item">
              <div class="stat-value orange"><%= device.today_customers || 0 %></div>
              <div class="stat-label">Customers Today</div>
            </div>
            <div class="stat-item">
              <div class="stat-value">Ksh <%= Math.round(device.week_revenue || 0) %></div>
              <div class="stat-label">This Week</div>
            </div>
            <div class="stat-item">
              <div class="stat-value">Ksh <%= Math.round(device.month_revenue || 0) %></div>
              <div class="stat-label">This Month</div>
            </div>
          </div>

          <% if (device.peak_hour !== null && typeof device.peak_hour !== 'undefined') { %>
            <div class="mb-2">
              <span class="peak-badge">
                <i class="fas fa-fire me-1"></i> 
                Peak: <%= device.peak_hour %>:00 - <%= device.peak_hour + 1 %>:00 
                (<%= device.peak_hour_count %> payments)
              </span>
            </div>
          <% } %>

          <div class="mt-3">
            <div class="d-flex justify-content-between">
              <small class="text-muted">Battery</small>
              <small class="text-muted"><%= device.battery_percent %>%</small>
            </div>
            <div class="battery-bar">
              <div class="battery-fill <%= device.battery_percent > 50 ? 'battery-good' : device.battery_percent > 20 ? 'battery-medium' : 'battery-low' %>" 
                   id="battery-<%= device.device_id %>"
                   style="width:<%= device.battery_percent %>%"></div>
            </div>
          </div>

          <div class="mt-2 d-flex justify-content-between align-items-center">
            <span id="status-<%= device.device_id %>" class="badge bg-<%= device.is_online ? 'success' : 'danger' %>"><%= device.status %></span>
            <small class="text-muted">
              <i class="far fa-clock me-1"></i>
              <span id="sync-<%= device.device_id %>"><%= device.last_sync ? new Date(device.last_sync).toLocaleString() : 'Never' %></span>
            </small>
          </div>
        </div>
      </a>
    <% }) %>
  <% } %>
</div>

<script src="/js/pwa.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

<script>
// Auto-refresh dashboard every 15 seconds
let autoRefreshInterval;
let refreshCount = 0;

function startAutoRefresh() {
  autoRefreshInterval = setInterval(() => {
    refreshCount++;
    fetch('/cuepay/api/dashboard-data')
      .then(res => res.json())
      .then(data => {
        if (data.success && data.devices) {
          updateDashboardCards(data.devices);
          const indicator = document.getElementById('refreshIndicator');
          if (indicator) {
            indicator.textContent = 'Last refresh: ' + new Date().toLocaleTimeString();
            indicator.style.color = '#10b981';
          }
        }
      })
      .catch(err => {
        console.log('Refresh error:', err);
        const indicator = document.getElementById('refreshIndicator');
        if (indicator) {
          indicator.textContent = 'Refresh failed';
          indicator.style.color = '#ef4444';
        }
      });
  }, 15000);
}

function updateDashboardCards(devices) {
  if (!devices || devices.length === 0) return;
  
  devices.forEach(device => {
    const gamesEl = document.getElementById('games-' + device.device_id);
    if (gamesEl) gamesEl.textContent = device.games_available || 0;
    
    const revEl = document.getElementById('revenue-' + device.device_id);
    if (revEl) revEl.textContent = 'Ksh ' + (device.today_revenue || 0);
    
    const battEl = document.getElementById('battery-' + device.device_id);
    if (battEl) {
      const percent = device.battery_voltage ? 
        Math.round(((device.battery_voltage - 10.5) / (12.6 - 10.5)) * 100) : 0;
      const safePercent = Math.max(0, Math.min(100, percent));
      battEl.style.width = safePercent + '%';
      battEl.className = 'battery-fill ' + 
        (safePercent > 50 ? 'battery-good' : safePercent > 20 ? 'battery-medium' : 'battery-low');
    }
    
    const statusEls = document.querySelectorAll('#status-' + device.device_id);
    statusEls.forEach(el => {
      const isOnline = device.status === 'online';
      el.textContent = isOnline ? 'online' : 'offline';
      el.className = 'badge mb-1 bg-' + (isOnline ? 'success' : 'danger');
    });
    
    const syncEl = document.getElementById('sync-' + device.device_id);
    if (syncEl && device.last_sync) {
      syncEl.textContent = new Date(device.last_sync).toLocaleString();
    }
  });
}

function manualRefresh() {
  clearInterval(autoRefreshInterval);
  startAutoRefresh();
  fetch('/cuepay/api/dashboard-data')
    .then(res => res.json())
    .then(data => {
      if (data.success && data.devices) {
        updateDashboardCards(data.devices);
      }
    });
}

document.addEventListener('DOMContentLoaded', () => {
  startAutoRefresh();
  
  const container = document.querySelector('.container.py-4');
  if (container) {
    const indicator = document.createElement('div');
    indicator.id = 'refreshIndicator';
    indicator.style.cssText = 'text-align:right;font-size:0.75rem;color:#10b981;margin-bottom:10px;';
    indicator.textContent = 'Auto-refresh active';
    container.insertBefore(indicator, container.firstChild);
  }
});

document.addEventListener('visibilitychange', () => {
  if (document.hidden) {
    clearInterval(autoRefreshInterval);
  } else {
    startAutoRefresh();
  }
});
</script>
<!-- Payment Sound Alert -->
<audio id="paymentSound" preload="auto">
  <source src="/sounds/payment.mp3" type="audio/mpeg">
</audio>

<script>
// ===== PAYMENT SOUND ALERT SYSTEM =====
let lastPaymentCount = 0;
let soundEnabled = true;

// Generate beep sound using Web Audio API (no file needed)
function playBeep(frequency = 800, duration = 0.15, volume = 0.3) {
  try {
    const audioContext = new (window.AudioContext || window.webkitAudioContext)();
    const oscillator = audioContext.createOscillator();
    const gainNode = audioContext.createGain();
    
    oscillator.connect(gainNode);
    gainNode.connect(audioContext.destination);
    
    oscillator.frequency.value = frequency;
    oscillator.type = 'sine';
    gainNode.gain.value = volume;
    
    oscillator.start();
    gainNode.gain.exponentialRampToValueAtTime(0.001, audioContext.currentTime + duration);
    oscillator.stop(audioContext.currentTime + duration);
  } catch(e) {
    console.log('Audio not supported');
  }
}

// Play payment success sound (ascending tones)
function playPaymentSound(amount) {
  if (!soundEnabled) return;
  
  const baseFreq = amount > 100 ? 600 : amount > 50 ? 500 : 400;
  
  // Play three ascending beeps
  setTimeout(() => playBeep(baseFreq, 0.12, 0.3), 0);
  setTimeout(() => playBeep(baseFreq * 1.25, 0.12, 0.3), 150);
  setTimeout(() => playBeep(baseFreq * 1.5, 0.2, 0.4), 300);
  
  // Show payment notification
  showPaymentToast(amount);
}

// Play alert sound (for offline/low battery)
function playAlertSound() {
  if (!soundEnabled) return;
  playBeep(300, 0.3, 0.3);
  setTimeout(() => playBeep(250, 0.4, 0.3), 350);
}

// Show payment notification toast
function showPaymentToast(amount) {
  const toast = document.createElement('div');
  toast.style.cssText = `
    position: fixed;
    top: 20px;
    right: 20px;
    background: linear-gradient(135deg, #10b981, #059669);
    color: white;
    padding: 15px 25px;
    border-radius: 15px;
    font-weight: 700;
    font-size: 1.2rem;
    z-index: 9999;
    box-shadow: 0 10px 40px rgba(16,185,129,0.5);
    animation: slideIn 0.5s ease, slideOut 0.5s ease 3.5s forwards;
    display: flex;
    align-items: center;
    gap: 12px;
  `;
  toast.innerHTML = `
    <span style="font-size:2rem;">💰</span>
    <div>
      <div style="font-size:0.8rem;opacity:0.8;">New Payment!</div>
      <div>Ksh ${amount.toFixed(0)}</div>
    </div>
    <button onclick="this.parentElement.remove()" style="background:none;border:none;color:white;cursor:pointer;font-size:1.2rem;margin-left:10px;">✕</button>
  `;
  document.body.appendChild(toast);
  
  setTimeout(() => toast.remove(), 4000);
}

// Toggle sound button
function toggleSound() {
  soundEnabled = !soundEnabled;
  const btn = document.getElementById('soundToggleBtn');
  if (btn) {
    btn.innerHTML = soundEnabled ? '🔊 Sound ON' : '🔇 Sound OFF';
    btn.style.background = soundEnabled ? '#10b981' : '#ef4444';
  }
  if (soundEnabled) playBeep(500, 0.1, 0.2);
}

// Monitor for new payments in auto-refresh
const originalUpdateCards = updateDashboardCards;
updateDashboardCards = function(devices) {
  if (!devices || devices.length === 0) return;
  
  devices.forEach(device => {
    const currentRevenue = parseFloat(device.today_revenue || 0);
    const previousRevenue = parseFloat(device._previousRevenue || 0);
    
    // Check if revenue increased (new payment)
    if (currentRevenue > previousRevenue && previousRevenue > 0) {
      const paymentAmount = currentRevenue - previousRevenue;
      playPaymentSound(paymentAmount);
    }
    
    // Store current revenue for next comparison
    device._previousRevenue = currentRevenue;
  });
  
  // Call original function
  originalUpdateCards(devices);
};

// Add sound toggle button to dashboard
document.addEventListener('DOMContentLoaded', () => {
  const nav = document.querySelector('.cuepay-nav .container.py-2 .d-flex');
  if (nav) {
    const soundBtn = document.createElement('button');
    soundBtn.id = 'soundToggleBtn';
    soundBtn.className = 'btn btn-sm rounded-pill';
    soundBtn.style.cssText = 'background:#10b981;color:white;border:none;cursor:pointer;margin-left:auto;';
    soundBtn.innerHTML = '🔊 Sound ON';
    soundBtn.onclick = toggleSound;
    nav.appendChild(soundBtn);
  }
});

// CSS animations for toast
const style = document.createElement('style');
style.textContent = `
  @keyframes slideIn {
    from { transform: translateX(100%); opacity: 0; }
    to { transform: translateX(0); opacity: 1; }
  }
  @keyframes slideOut {
    from { transform: translateX(0); opacity: 1; }
    to { transform: translateX(100%); opacity: 0; }
  }
`;
document.head.appendChild(style);
</script>

</body>
</html>