<%- include('../layouts/main') %>
<style>
.cuepay-auth-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #0ea5e9, #0284c7, #0369a1);
  padding: 20px;
}
.cuepay-auth-card {
  background: white;
  border-radius: 25px;
  padding: 45px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.3);
  max-width: 460px;
  width: 100%;
}
.cuepay-logo { text-align: center; margin-bottom: 35px; }
.cuepay-logo i { font-size: 4rem; color: #0ea5e9; margin-bottom: 10px; }
.cuepay-logo h2 { font-weight: 800; color: #1e293b; margin: 0; }
.cuepay-logo p { color: #64748b; margin: 5px 0 0; }
</style>
</head>
<body>
<div class="cuepay-auth-page">
  <div class="cuepay-auth-card">
    <div class="cuepay-logo">
      <i class="fas fa-water"></i>
      <h2>CuePay</h2>
      <p>Pool Automation System</p>
    </div>
    <% if (typeof success_msg !== 'undefined' && success_msg && success_msg.length > 0) { %>
      <div class="alert alert-success"><%= success_msg %></div>
    <% } %>
    <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
      <div class="alert alert-danger"><%= error_msg %></div>
    <% } %>
    <form action="/cuepay/login" method="POST">
      <div class="mb-3">
        <label class="form-label">Email</label>
        <input type="email" name="email" class="form-control" placeholder="Enter your email" required>
      </div>
      <div class="mb-3">
        <label class="form-label">Password</label>
        <input type="password" name="password" class="form-control" placeholder="Enter your password" required>
      </div>
      <button type="submit" class="btn btn-primary w-100 py-3 fw-bold" style="background:#0ea5e9;border:none;border-radius:50px;">
        <i class="fas fa-sign-in-alt me-2"></i> Login to CuePay
      </button>
    </form>
    <div class="text-center mt-3">
      <p>Don't have an account? <a href="/cuepay/register" style="color:#0ea5e9;font-weight:600;">Register here</a></p>
      <a href="/" class="text-muted" style="font-size:0.9rem;">← Back to Ardthon Solutions</a>
    </div>
  </div>
</div>
</body>
</html>