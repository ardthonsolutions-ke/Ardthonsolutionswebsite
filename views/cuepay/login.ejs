<%- include('../layouts/main') %>
<style>
    .cuepay-nav {
        background: linear-gradient(135deg, #0ea5e9, #0284c7);
        padding: 15px 0;
    }
    .cuepay-nav .nav-link {
        color: white !important;
    }
    .device-card {
        background: white;
        border-radius: 15px;
        padding: 25px;
        box-shadow: 0 5px 20px rgba(0,0,0,0.1);
        transition: all 0.3s;
        position: relative;
        overflow: hidden;
    }
    .device-card:hover {
        transform: translateY(-5px);
        box-shadow: 0 15px 40px rgba(0,0,0,0.15);
    }
    .device-card.online { border-left: 4px solid #10b981; }
    .device-card.offline { border-left: 4px solid #ef4444; opacity: 0.7; }
    .games-count {
        font-size: 3rem;
        font-weight: 800;
        color: #0ea5e9;
    }
    .battery-indicator {
        height: 8px;
        background: #e5e7eb;
        border-radius: 4px;
        overflow: hidden;
    }
    .battery-fill {
        height: 100%;
        border-radius: 4px;
        transition: width 0.5s;
    }
    .battery-good { background: #10b981; }
    .battery-medium { background: #f59e0b; }
    .battery-low { background: #ef4444; }
</style>
</head>
<body>
    <nav class="cuepay-nav">
        <div class="container d-flex justify-content-between align-items-center">
            <a href="/cuepay/dashboard" class="text-white text-decoration-none">
                <i class="fas fa-water fa-2x me-2"></i>
                <span class="h4 fw-bold">CuePay</span>
            </a>
            <div>
                <span class="text-white me-3">Welcome, <%= user.name %></span>
                <a href="/cuepay/register-device" class="btn btn-light btn-sm me-2">
                    <i class="fas fa-plus me-1"></i> Add Device
                </a>
                <a href="/cuepay/logout" class="btn btn-outline-light btn-sm">Logout</a>
            </div>
        </div>
    </nav>
    
    <div class="container py-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h2>Your Devices</h2>
            <a href="/cuepay/register-device" class="btn btn-primary rounded-pill">
                <i class="fas fa-plus me-2"></i> Register New Device
            </a>
        </div>
        
        <% if (devices.length === 0) { %>
            <div class="text-center py-5">
                <i class="fas fa-microchip fa-5x text-muted mb-3"></i>
                <h3>No Devices Yet</h3>
                <p>Register your first CuePay device to get started</p>
                <a href="/cuepay/register-device" class="btn btn-primary btn-lg rounded-pill">
                    Register Device
                </a>
            </div>
        <% } else { %>
            <div class="row g-4">
                <% devices.forEach(device => { %>
                    <div class="col-md-6 col-lg-4">
                        <a href="/cuepay/device/<%= device.device_id %>" class="text-decoration-none">
                            <div class="device-card <%= device.status %>">
                                <div class="d-flex justify-content-between align-items-start mb-3">
                                    <div>
                                        <h5 class="mb-1"><%= device.device_name %></h5>
                                        <small class="text-muted"><%= device.device_id %></small>
                                    </div>
                                    <span class="badge bg-<%= device.is_online ? 'success' : 'danger' %>">
                                        <%= device.status %>
                                    </span>
                                </div>
                                
                                <div class="row text-center mb-3">
                                    <div class="col-6">
                                        <div class="games-count"><%= device.games_available || 0 %></div>
                                        <small class="text-muted">Games Left</small>
                                    </div>
                                    <div class="col-6">
                                        <div class="h3 fw-bold text-success">Ksh <%= device.today_revenue || 0 %></div>
                                        <small class="text-muted">Today Revenue</small>
                                    </div>
                                </div>
                                
                                <div class="mb-2">
                                    <div class="d-flex justify-content-between mb-1">
                                        <small>Battery</small>
                                        <small><%= device.battery_percent %>%</small>
                                    </div>
                                    <div class="battery-indicator">
                                        <div class="battery-fill <%= 
                                            device.battery_percent > 50 ? 'battery-good' : 
                                            device.battery_percent > 20 ? 'battery-medium' : 'battery-low'
                                        %>" style="width: <%= device.battery_percent %>%"></div>
                                    </div>
                                </div>
                                
                                <small class="text-muted">
                                    <i class="far fa-clock me-1"></i> Last activity: <%= device.last_activity %>
                                </small>
                            </div>
                        </a>
                    </div>
                <% }) %>
            </div>
        <% } %>
    </div>
</body>
</html>