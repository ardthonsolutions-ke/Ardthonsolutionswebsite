<%- include('../layouts/main') %>
</head>
<body>
    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card shadow-lg border-0 rounded-4">
                    <div class="card-body p-5 text-center">
                        <i class="fas fa-check-circle fa-4x text-success mb-3"></i>
                        <h2>Device Registered!</h2>
                        <p class="text-muted mb-4">Configure your device with these credentials:</p>
                        
                        <div class="bg-light rounded-3 p-4 mb-3 text-start">
                            <div class="mb-3">
                                <label class="fw-bold text-muted">Device ID:</label>
                                <div class="bg-white p-2 rounded border code-font">
                                    <%= deviceId %>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="fw-bold text-muted">API Key:</label>
                                <div class="bg-white p-2 rounded border code-font" style="word-break: break-all;">
                                    <%= apiKey %>
                                </div>
                            </div>
                            <div class="mb-3">
                                <label class="fw-bold text-muted">API URL:</label>
                                <div class="bg-white p-2 rounded border code-font">
                                    https://ardthonsolutions.com/cuepay/api/sync
                                </div>
                            </div>
                        </div>
                        
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <strong>Important:</strong> Save these credentials. The API key will not be shown again.
                        </div>
                        
                        <div class="d-flex gap-2">
                            <button onclick="copyCredentials()" class="btn btn-outline-primary flex-fill">
                                <i class="fas fa-copy me-2"></i> Copy All
                            </button>
                            <a href="/cuepay/dashboard" class="btn btn-primary flex-fill">
                                <i class="fas fa-tachometer-alt me-2"></i> Go to Dashboard
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        function copyCredentials() {
            const text = `Device ID: <%= deviceId %>\nAPI Key: <%= apiKey %>\nAPI URL: https://ardthonsolutions.com/cuepay/api/sync`;
            navigator.clipboard.writeText(text).then(() => {
                alert('Credentials copied to clipboard!');
            });
        }
    </script>
</body>
</html>