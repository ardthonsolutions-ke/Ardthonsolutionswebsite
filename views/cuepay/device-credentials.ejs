<%- include('../layouts/main') %>
</head>
<body>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">
      <div class="card shadow-lg border-0 rounded-4">
        <div class="card-body p-5 text-center">
          <i class="fas fa-check-circle fa-4x text-success mb-3"></i>
          <h2>Device Registered Successfully!</h2>
          <p class="text-muted mb-4">Configure your CuePay device with these credentials:</p>
          <div class="bg-light rounded-3 p-4 mb-3 text-start">
            <div class="mb-3">
              <label class="fw-bold text-muted">Device Name:</label>
              <div class="bg-white p-3 rounded border mt-1 fw-bold"><%= device.device_name %></div>
            </div>
            <div class="mb-3">
              <label class="fw-bold text-muted">Device ID:</label>
              <div class="bg-white p-3 rounded border mt-1" style="font-family:monospace;font-size:0.9rem;word-break:break-all;"><%= device.device_id %></div>
            </div>
            <div class="mb-3">
              <label class="fw-bold text-muted">API Key:</label>
              <div class="bg-white p-3 rounded border mt-1" style="font-family:monospace;font-size:0.85rem;word-break:break-all;"><%= device.api_key %></div>
            </div>
            <div class="mb-0">
              <label class="fw-bold text-muted">API Sync URL:</label>
              <div class="bg-white p-3 rounded border mt-1" style="font-family:monospace;font-size:0.85rem;">https://ardthonsolutions.com/cuepay/api/sync</div>
            </div>
          </div>
          <div class="alert alert-warning text-start">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Important:</strong> Save these credentials now. The API Key cannot be viewed again.
          </div>
          <div class="d-flex gap-2">
            <button onclick="copyAll()" class="btn btn-outline-primary flex-fill rounded-pill"><i class="fas fa-copy me-2"></i> Copy All</button>
            <a href="/cuepay/dashboard" class="btn btn-primary flex-fill rounded-pill" style="background:#0ea5e9;"><i class="fas fa-tachometer-alt me-2"></i> Go to Dashboard</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
function copyAll() {
  var text = "Device Name: <%= device.device_name %>\nDevice ID: <%= device.device_id %>\nAPI Key: <%= device.api_key %>\nAPI URL: https://ardthonsolutions.com/cuepay/api/sync";
  navigator.clipboard.writeText(text).then(function() {
    alert('Credentials copied to clipboard!');
  }).catch(function() {
    prompt('Copy these credentials:', text);
  });
}
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>