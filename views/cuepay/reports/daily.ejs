<%- include('../../layouts/main') %>
<style>
.cuepay-nav { background: linear-gradient(135deg, #0ea5e9, #0284c7); padding: 15px 0; }
.cuepay-nav a { color: white !important; text-decoration: none; }
.report-card { background: white; border-radius: 15px; padding: 25px; box-shadow: 0 5px 20px rgba(0,0,0,0.1); margin-bottom: 20px; }
.report-card h4 { color: #0ea5e9; }
.stat-big { font-size: 2.5rem; font-weight: 800; color: #1e293b; }
.stat-label { font-size: 0.8rem; color: #64748b; text-transform: uppercase; letter-spacing: 1px; }
.hour-bar { display: flex; height: 30px; align-items: flex-end; gap: 2px; margin: 10px 0; }
.hour-segment { flex: 1; background: #0ea5e9; border-radius: 3px 3px 0 0; min-height: 2px; position: relative; }
.hour-segment:hover { opacity: 0.7; }
.hour-label { font-size: 0.6rem; color: #64748b; text-align: center; }
.goal-progress { height: 10px; background: #e5e7eb; border-radius: 5px; overflow: hidden; margin-top: 5px; }
.goal-fill { height: 100%; background: #10b981; border-radius: 5px; transition: width 1s; }
.export-btn { float: right; }
</style>
</head>
<body>
<nav class="cuepay-nav">
  <div class="container">
    <a href="/cuepay/dashboard"><i class="fas fa-arrow-left me-2"></i> Back to Dashboard</a>
    <span class="text-white ms-3">|</span>
    <a href="/cuepay/reports/daily" class="text-white ms-3 fw-bold">Daily</a>
    <a href="/cuepay/reports/weekly" class="text-white ms-3">Weekly</a>
    <a href="/cuepay/reports/monthly" class="text-white ms-3">Monthly</a>
  </div>
</nav>

<div class="container py-4">
  <h2 class="mb-4">Daily Report - <%= selectedDate %></h2>

  <% if (reports.length === 0) { %>
    <div class="text-center py-5"><p class="text-muted">No data available for this date.</p></div>
  <% } %>

  <% reports.forEach(function(report) { %>
    <div class="report-card">
      <h4><%= report.device_name %></h4>
      <small class="text-muted"><%= report.device_id %></small>

      <div class="row mt-3">
        <div class="col-3 text-center">
          <div class="stat-big"><%= report.stats.games || 0 %></div>
          <div class="stat-label">Games Played</div>
        </div>
        <div class="col-3 text-center">
          <div class="stat-big text-success">Ksh <%= report.stats.revenue || 0 %></div>
          <div class="stat-label">Revenue</div>
        </div>
        <div class="col-3 text-center">
          <div class="stat-big"><%= report.stats.customers || 0 %></div>
          <div class="stat-label">Customers</div>
        </div>
        <div class="col-3 text-center">
          <div class="stat-big">Ksh <%= Math.round(report.stats.avg_payment || 0) %></div>
          <div class="stat-label">Avg Payment</div>
        </div>
      </div>

      <!-- Hourly Chart -->
      <% if (report.hourly_breakdown.length > 0) { %>
        <div class="mt-3">
          <small class="text-muted">Hourly Activity</small>
          <div class="hour-bar">
            <% for (var h = 0; h < 24; h++) { 
              var hourData = report.hourly_breakdown.find(function(hd) { return hd.hour === h; });
              var height = hourData ? Math.max(5, (hourData.payments / Math.max.apply(null, report.hourly_breakdown.map(function(hd){return hd.payments;})) * 100)) : 2;
            %>
              <div class="hour-segment" style="height:<%= height %>%;" title="<%= h %>:00 - <%= hourData ? hourData.payments + ' payments, Ksh ' + hourData.revenue : 'No activity' %>"></div>
            <% } %>
          </div>
          <div style="display:flex;justify-content:space-between;">
            <span class="hour-label">0h</span><span class="hour-label">6h</span><span class="hour-label">12h</span><span class="hour-label">18h</span><span class="hour-label">23h</span>
          </div>
        </div>
      <% } %>

      <!-- First & Last Game -->
      <div class="mt-3 d-flex justify-content-between">
        <small class="text-muted">First: <%= report.stats.first_game ? new Date(report.stats.first_game).toLocaleTimeString() : 'N/A' %></small>
        <small class="text-muted">Last: <%= report.stats.last_game ? new Date(report.stats.last_game).toLocaleTimeString() : 'N/A' %></small>
      </div>

      <a href="/cuepay/export/csv/<%= report.device_id %>" class="btn btn-sm btn-outline-primary rounded-pill mt-2">
        <i class="fas fa-download me-1"></i> Export CSV
      </a>
    </div>
  <% }) %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>