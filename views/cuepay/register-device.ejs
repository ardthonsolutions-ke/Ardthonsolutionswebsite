<%- include('../layouts/main') %>
<style>
.cuepay-nav { background: linear-gradient(135deg, #0ea5e9, #0284c7); padding: 15px 0; }
.cuepay-nav a { color: white !important; text-decoration: none; font-weight: 500; }
</style>
</head>
<body>
<nav class="cuepay-nav">
  <div class="container">
    <a href="/cuepay/dashboard"><i class="fas fa-arrow-left me-2"></i> Back to Dashboard</a>
  </div>
</nav>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-6">
      <h2 class="text-center mb-4"><i class="fas fa-plus-circle" style="color:#0ea5e9;"></i> Register New CuePay Device</h2>

      <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
        <div class="alert alert-danger"><%= error_msg %></div>
      <% } %>

      <div class="card shadow border-0 rounded-4">
        <div class="card-body p-4">
          <form action="/cuepay/register-device" method="POST">
            <div class="mb-3">
              <label class="form-label fw-bold">Device Name *</label>
              <input type="text" name="device_name" class="form-control" placeholder="e.g., Main Hall Table 1" required>
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Location</label>
              <select name="location" class="form-select">
                <option>Main Hall</option>
                <option>VIP Room</option>
                <option>Outdoor</option>
                <option>Bar Area</option>
                <option>Lounge</option>
                <option>Other</option>
              </select>
            </div>
            <div class="mb-3">
              <label class="form-label fw-bold">Price per Game (Ksh)</label>
              <input type="number" name="game_price" class="form-control" value="10" min="1" step="0.01" required>
            </div>
            <button type="submit" class="btn btn-primary w-100 py-3 rounded-pill fw-bold" style="background:#0ea5e9;border:none;">
              <i class="fas fa-check me-2"></i> Register Device
            </button>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>