<%- include('../layouts/main') %>
<style>
.attendx-auth-page {
  min-height: 100vh;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #1a1a2e, #0f0f1a);
  padding: 20px;
}
.attendx-auth-card {
  background: #1a1a2e;
  border: 1px solid #2a2a4a;
  border-radius: 25px;
  padding: 45px;
  box-shadow: 0 25px 60px rgba(0,0,0,0.5);
  max-width: 500px;
  width: 100%;
}
</style>
</head>
<body>
<div class="attendx-auth-page">
  <div class="attendx-auth-card">
    <div class="text-center mb-4">
      <i class="fas fa-school fa-3x" style="color:#8b5cf6;"></i>
      <h2 class="fw-bold mt-2" style="color:#fff;">Create AttendX Account</h2>
      <p style="color:#8888aa;">Register your school or office</p>
    </div>
    <% if (typeof error_msg !== 'undefined' && error_msg && error_msg.length > 0) { %>
      <div class="alert alert-danger"><%= error_msg %></div>
    <% } %>
    <form action="/attendx/register" method="POST">
      <div class="mb-3">
        <label style="color:#ccccdd;">Full Name</label>
        <input type="text" name="full_name" class="form-control" style="background:#0a0a16;border:1px solid #2a2a4a;color:#fff;" required>
      </div>
      <div class="mb-3">
        <label style="color:#ccccdd;">Institution Name</label>
        <input type="text" name="institution_name" class="form-control" style="background:#0a0a16;border:1px solid #2a2a4a;color:#fff;" placeholder="School or Office name">
      </div>
      <div class="mb-3">
        <label style="color:#ccccdd;">Institution Type</label>
        <select name="institution_type" class="form-select" style="background:#0a0a16;border:1px solid #2a2a4a;color:#fff;">
          <option value="School">School</option>
          <option value="College">College</option>
          <option value="Office">Office</option>
          <option value="Other">Other</option>
        </select>
      </div>
      <div class="mb-3">
        <label style="color:#ccccdd;">Phone</label>
        <input type="text" name="phone" class="form-control" style="background:#0a0a16;border:1px solid #2a2a4a;color:#fff;">
      </div>
      <div class="mb-3">
        <label style="color:#ccccdd;">Email</label>
        <input type="email" name="email" class="form-control" style="background:#0a0a16;border:1px solid #2a2a4a;color:#fff;" required>
      </div>
      <div class="mb-3">
        <label style="color:#ccccdd;">Password</label>
        <input type="password" name="password" class="form-control" style="background:#0a0a16;border:1px solid #2a2a4a;color:#fff;" required minlength="6">
      </div>
      <div class="mb-3">
        <label style="color:#ccccdd;">Confirm Password</label>
        <input type="password" name="password2" class="form-control" style="background:#0a0a16;border:1px solid #2a2a4a;color:#fff;" required>
      </div>
      <button type="submit" class="btn w-100 py-3 fw-bold" style="background:#8b5cf6;color:#fff;border-radius:50px;">
        Create Account
      </button>
    </form>
    <div class="text-center mt-3">
      <p style="color:#8888aa;">Already have an account? <a href="/attendx/login" style="color:#8b5cf6;">Login</a></p>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>