<%- include('../layouts/main') %>
<style>
.attendx-nav { background: linear-gradient(135deg, #1a1a2e, #0f0f1a); border-bottom: 2px solid #8b5cf6; padding: 15px 0; }
.attendx-nav a { color: #e0e0e0 !important; text-decoration: none; }
body { background: #0f0f1a; }
.card-dark { background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 15px; padding: 20px; margin-bottom: 20px; }
</style>
</head>
<body>
<nav class="attendx-nav">
  <div class="container d-flex justify-content-between">
    <a href="/attendx/dashboard"><i class="fas fa-arrow-left me-2"></i> Back</a>
    <button class="btn btn-sm rounded-pill" style="background:#8b5cf6;color:#fff;" onclick="location.reload()"><i class="fas fa-sync-alt me-1"></i> Refresh</button>
  </div>
</nav>

<div class="container py-4">
  <h2 style="color:#fff;"><%= device.device_name %></h2>
  <p style="color:#888;"><%= device.device_id %> | Status: <span style="color:<%= device.status === 'online' ? '#10b981' : '#ef4444' %>;"><%= device.status %></span></p>

  <div class="row g-3 mb-4">
    <div class="col-md-3">
      <div class="card-dark text-center">
        <div class="stat-value" style="color:#10b981;font-size:2rem;font-weight:800;"><%= todayStats.entries || 0 %></div>
        <div class="stat-label" style="color:#888;">Today Entries</div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card-dark text-center">
        <div class="stat-value" style="color:#f59e0b;font-size:2rem;font-weight:800;"><%= todayStats.exits || 0 %></div>
        <div class="stat-label" style="color:#888;">Today Exits</div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card-dark text-center">
        <div class="stat-value" style="color:#8b5cf6;font-size:2rem;font-weight:800;"><%= students.length || 0 %></div>
        <div class="stat-label" style="color:#888;">Total Students</div>
      </div>
    </div>
    <div class="col-md-3">
      <div class="card-dark text-center">
        <div class="stat-value" style="color:#fff;font-size:2rem;font-weight:800;"><%= records.length || 0 %></div>
        <div class="stat-label" style="color:#888;">Records Shown</div>
      </div>
    </div>
  </div>

  <!-- Add Student Form -->
  <div class="card-dark">
    <h4 style="color:#8b5cf6;">Add Student</h4>
    <form action="/attendx/device/<%= device.device_id %>/student" method="POST" style="display:flex;gap:10px;flex-wrap:wrap;">
      <input type="text" name="student_id" placeholder="Student ID" required style="background:#0a0a16;color:#fff;border:1px solid #2a2a4a;padding:10px;border-radius:8px;flex:1;">
      <input type="text" name="full_name" placeholder="Full Name" required style="background:#0a0a16;color:#fff;border:1px solid #2a2a4a;padding:10px;border-radius:8px;flex:2;">
      <input type="text" name="class_grade" placeholder="Class/Grade" style="background:#0a0a16;color:#fff;border:1px solid #2a2a4a;padding:10px;border-radius:8px;flex:1;">
      <input type="text" name="parent_name" placeholder="Parent Name" style="background:#0a0a16;color:#fff;border:1px solid #2a2a4a;padding:10px;border-radius:8px;flex:2;">
      <input type="text" name="parent_phone" placeholder="Parent Phone (+254...)" required style="background:#0a0a16;color:#fff;border:1px solid #2a2a4a;padding:10px;border-radius:8px;flex:2;">
      <input type="number" name="fingerprint_id" placeholder="Fingerprint ID" style="background:#0a0a16;color:#fff;border:1px solid #2a2a4a;padding:10px;border-radius:8px;flex:1;">
      <button type="submit" style="background:#8b5cf6;color:#fff;border:none;padding:10px 25px;border-radius:8px;font-weight:700;">Add Student</button>
    </form>
  </div>

  <!-- Student List -->
  <div class="card-dark">
    <h4 style="color:#8b5cf6;">Registered Students</h4>
    <div class="table-responsive">
      <table class="table" style="color:#ccc;">
        <thead><tr><th>ID</th><th>Name</th><th>Class</th><th>Parent</th><th>Phone</th><th>FP ID</th></tr></thead>
        <tbody>
          <% students.forEach(function(s) { %>
            <tr><td><%= s.student_id %></td><td><%= s.full_name %></td><td><%= s.class_grade || '-' %></td><td><%= s.parent_name || '-' %></td><td><%= s.parent_phone %></td><td><%= s.fingerprint_id || '-' %></td></tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <!-- Recent Records -->
  <div class="card-dark">
    <h4 style="color:#8b5cf6;">Recent Attendance</h4>
    <div class="table-responsive">
      <table class="table" style="color:#ccc;">
        <thead><tr><th>Time</th><th>Student</th><th>Type</th><th>Parent SMS</th></tr></thead>
        <tbody>
          <% records.forEach(function(r) { %>
            <tr>
              <td><%= new Date(r.recorded_at).toLocaleString() %></td>
              <td><%= r.student_name || r.student_id %></td>
              <td><span class="badge bg-<%= r.event_type === 'entry' ? 'success' : 'warning' %>"><%= r.event_type %></span></td>
              <td><%= r.sms_sent ? '✅ Sent' : '⏳ Pending' %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
ENDOFFILE