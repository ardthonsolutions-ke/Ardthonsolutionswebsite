cat > /home/yxmvmjxp/ardthonapp/views/attendx/device-credentials.ejs << 'ENDOFFILE'
<%- include('../layouts/main') %>
</head>
<body>
<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-7">
      <div class="card shadow-lg border-0 rounded-4" style="background:#1a1a2e;border:1px solid #2a2a4a;">
        <div class="card-body p-5 text-center">
          <i class="fas fa-check-circle fa-4x text-success mb-3"></i>
          <h2 style="color:#fff;">Device Registered!</h2>
          <p style="color:#888;">Configure your AttendX device with these credentials:</p>
          <div class="bg-dark rounded-3 p-4 mb-3 text-start">
            <div class="mb-3">
              <label class="fw-bold" style="color:#888;">Device Name:</label>
              <div class="p-3 rounded border mt-1 fw-bold" style="background:#0a0a16;color:#fff;border-color:#2a2a4a;"><%= device.device_name %></div>
            </div>
            <div class="mb-3">
              <label class="fw-bold" style="color:#888;">Device ID:</label>
              <div class="p-3 rounded border mt-1" style="background:#0a0a16;color:#8b5cf6;border-color:#2a2a4a;font-family:monospace;word-break:break-all;"><%= device.device_id %></div>
            </div>
            <div class="mb-3">
              <label class="fw-bold" style="color:#888;">API Key:</label>
              <div class="p-3 rounded border mt-1" style="background:#0a0a16;color:#8b5cf6;border-color:#2a2a4a;font-family:monospace;font-size:0.85rem;word-break:break-all;"><%= device.api_key %></div>
            </div>
            <div class="mb-0">
              <label class="fw-bold" style="color:#888;">API URL:</label>
              <div class="p-3 rounded border mt-1" style="background:#0a0a16;color:#fff;border-color:#2a2a4a;font-family:monospace;">https://ardthonsolutions.com/attendx/api/sync</div>
            </div>
          </div>
          <div class="alert alert-warning text-start">
            <i class="fas fa-exclamation-triangle me-2"></i>
            <strong>Save these credentials!</strong> The API Key cannot be viewed again.
          </div>
          <div class="d-flex gap-2">
            <button onclick="copyAll()" class="btn btn-outline-light flex-fill rounded-pill"><i class="fas fa-copy me-2"></i> Copy All</button>
            <a href="/attendx/dashboard" class="btn flex-fill rounded-pill" style="background:#8b5cf6;color:#fff;"><i class="fas fa-tachometer-alt me-2"></i> Dashboard</a>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<script>
function copyAll() {
  var text = "Device Name: <%= device.device_name %>\nDevice ID: <%= device.device_id %>\nAPI Key: <%= device.api_key %>\nAPI URL: https://ardthonsolutions.com/attendx/api/sync";
  navigator.clipboard.writeText(text).then(function() { alert('Copied!'); }).catch(function() { prompt('Copy:', text); });
}
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
ENDOFFILE