<%- include('../layouts/main') %>
<style>
.attendx-nav { background: linear-gradient(135deg, #1a1a2e, #0f0f1a); border-bottom: 2px solid #8b5cf6; padding: 15px 0; }
.attendx-nav a { color: #e0e0e0 !important; text-decoration: none; font-weight: 500; }
.device-card {
  background: #1a1a2e; border: 1px solid #2a2a4a; border-radius: 15px; padding: 25px;
  box-shadow: 0 5px 20px rgba(0,0,0,0.3); transition: all 0.3s;
  border-left: 4px solid #2a2a4a; margin-bottom: 25px;
}
.device-card:hover { transform: translateY(-3px); border-color: #8b5cf6; }
.device-card.online { border-left-color: #10b981; }
.device-card.offline { border-left-color: #ef4444; opacity: 0.7; }
.stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); gap: 12px; margin-bottom: 15px; }
.stat-item { background: rgba(0,0,0,0.3); padding: 12px; border-radius: 10px; text-align: center; border: 1px solid #2a2a4a; }
.stat-value { font-size: 1.5rem; font-weight: 800; color: #8b5cf6; }
.stat-label { font-size: 0.7rem; color: #8888aa; text-transform: uppercase; letter-spacing: 0.5px; }
.stat-value.green { color: #10b981; }
.stat-value.orange { color: #f59e0b; }
</style>
</head>
<body>
<nav class="attendx-nav">
  <div class="container d-flex justify-content-between align-items-center">
    <a href="/attendx/dashboard" class="text-decoration-none">
      <i class="fas fa-school fa-2x me-2" style="color:#8b5cf6;"></i><span class="h4 fw-bold" style="color:#fff;">AttendX</span>
    </a>
    <div>
      <a href="/attendx/register-device" class="btn btn-sm me-2 rounded-pill" style="background:#8b5cf6;color:#fff;"><i class="fas fa-plus me-1"></i> Add Device</a>
      <a href="/attendx/logout" class="btn btn-sm rounded-pill" style="border:1px solid #444;color:#ccc;">Logout</a>
    </div>
  </div>
</nav>

<div class="container py-4">
  <h2 style="color:#fff;margin-bottom:25px;">Your Attendance Devices</h2>

  <% if (typeof devices === 'undefined' || devices.length === 0) { %>
    <div class="text-center py-5">
      <i class="fas fa-microchip fa-5x text-muted mb-3"></i>
      <h3 style="color:#fff;">No Devices Registered</h3>
      <p style="color:#888;">Register your first AttendX device</p>
      <a href="/attendx/register-device" class="btn btn-lg rounded-pill" style="background:#8b5cf6;color:#fff;">Register Device</a>
    </div>
  <% } else { %>
    <% devices.forEach(function(device) { %>
      <a href="/attendx/device/<%= device.device_id %>" class="text-decoration-none">
        <div class="device-card <%= device.is_online ? 'online' : 'offline' %>">
          <div class="d-flex justify-content-between align-items-start mb-3">
            <div>
              <h4 style="color:#fff;"><%= device.device_name %></h4>
              <small style="color:#888;"><%= device.device_id %> • <%= device.location_area || 'N/A' %></small>
            </div>
            <span class="badge bg-<%= device.is_online ? 'success' : 'danger' %>"><%= device.status %></span>
          </div>
          <div class="stat-grid">
            <div class="stat-item"><div class="stat-value green"><%= device.today_entries || 0 %></div><div class="stat-label">Today Entries</div></div>
            <div class="stat-item"><div class="stat-value orange"><%= device.today_exits || 0 %></div><div class="stat-label">Today Exits</div></div>
            <div class="stat-item"><div class="stat-value"><%= device.student_count || 0 %></div><div class="stat-label">Students</div></div>
          </div>
          <small style="color:#888;">Last sync: <%= device.last_sync ? new Date(device.last_sync).toLocaleString() : 'Never' %></small>
        </div>
      </a>
    <% }) %>
  <% } %>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>