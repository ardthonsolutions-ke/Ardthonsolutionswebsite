<%- include('../layouts/main') %>
<style>
.admin-nav { background: #1a1a2e; border-bottom: 2px solid #00d4ff; padding: 15px 0; }
.admin-nav a { color: #e0e0e0; text-decoration: none; margin: 0 15px; }
body { background: #0f0f1a; }
</style>
</head>
<body style="background:#0f0f1a;">

<nav class="admin-nav">
  <div class="container">
    <a href="/admin">📊 Dashboard</a>
    <a href="/admin/users">👥 Users</a>
    <a href="/admin/payments" class="active">💰 Payments</a>
    <a href="/auth/logout" style="float:right;">🚪 Logout</a>
  </div>
</nav>

<div class="container py-4">
  <h1 style="color:#fff;">All Payments</h1>
  <p style="color:#888;">Total: Ksh <%= typeof totals !== 'undefined' ? totals.total : 0 %> (<%= typeof totals !== 'undefined' ? totals.count : 0 %> payments)</p>
  <table style="width:100%;color:#ccc;">
    <thead><tr><th>TX ID</th><th>Amount</th><th>Customer</th><th>Games</th><th>Device</th><th>Owner</th><th>Time</th></tr></thead>
    <tbody>
      <% if (typeof payments !== 'undefined' && payments.length > 0) { %>
        <% payments.forEach(function(p) { %>
          <tr>
            <td style="font-size:0.75rem;"><%= p.transaction_id %></td>
            <td>Ksh <%= p.amount %></td>
            <td><%= p.customer_number %></td>
            <td><%= p.games_earned %></td>
            <td><%= p.device_name || p.device_id %></td>
            <td><%= p.owner_email || 'N/A' %></td>
            <td style="font-size:0.75rem;"><%= new Date(p.payment_time).toLocaleString() %></td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="7" style="text-align:center;">No payments found.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>