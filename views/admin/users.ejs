<%- include('../layouts/main') %>
<style>
.admin-nav { background: #1a1a2e; border-bottom: 2px solid #00d4ff; padding: 15px 0; }
.admin-nav a { color: #e0e0e0; text-decoration: none; margin: 0 15px; }
body { background: #0f0f1a; }
</style>
</head>
<body style="background:#0f0f1a;">

<nav class="admin-nav">
  <div class="container">
    <a href="/admin">📊 Dashboard</a>
    <a href="/admin/users" class="active">👥 Users</a>
    <a href="/admin/payments">💰 Payments</a>
    <a href="/auth/logout" style="float:right;">🚪 Logout</a>
  </div>
</nav>

<div class="container py-4">
  <h1 style="color:#fff;">All Users</h1>
  <table style="width:100%;color:#ccc;">
    <thead><tr><th>Name</th><th>Email</th><th>Devices</th><th>Revenue</th><th>Joined</th><th>Actions</th></tr></thead>
    <tbody>
      <% if (typeof users !== 'undefined' && users.length > 0) { %>
        <% users.forEach(function(u) { %>
          <tr>
            <td><%= u.full_name || u.username %></td>
            <td><%= u.email %></td>
            <td><%= u.device_count || 0 %></td>
            <td>Ksh <%= u.total_revenue || 0 %></td>
            <td><%= new Date(u.created_at).toLocaleDateString() %></td>
            <td>
              <form action="/admin/users/<%= u.id %>/delete" method="POST" onsubmit="return confirm('Delete user and all their devices?');">
                <button type="submit" style="background:#ef4444;color:#fff;border:none;padding:5px 15px;border-radius:15px;">Delete</button>
              </form>
            </td>
          </tr>
        <% }) %>
      <% } else { %>
        <tr><td colspan="6" style="text-align:center;">No users found.</td></tr>
      <% } %>
    </tbody>
  </table>
</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>