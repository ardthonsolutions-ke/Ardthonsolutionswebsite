<%- include('layouts/main') %>
<style>
:root {
  --bg-dark: #0f0f1a;
  --bg-card: #1a1a2e;
  --bg-card-hover: #222240;
  --text-primary: #e0e0e0;
  --text-muted: #8888aa;
  --accent: #00d4ff;
  --accent-dark: #0099cc;
  --border: #2a2a4a;
}

body { background: var(--bg-dark); }

/* Hero Slideshow */
.hero-slideshow {
  position: relative;
  height: 550px;
  overflow: hidden;
  background: #0a0a14;
}
.hero-slide {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  object-fit: cover;
  opacity: 0;
  transition: opacity 1.2s ease-in-out;
  filter: brightness(0.5) saturate(0.8);
}
.hero-slide.active { opacity: 1; }
.hero-overlay {
  position: absolute;
  top: 0; left: 0;
  width: 100%; height: 100%;
  background: linear-gradient(135deg, rgba(15,15,26,0.85) 0%, rgba(26,26,46,0.7) 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  text-align: center;
  z-index: 2;
}
.hero-content h1 {
  font-size: 3.5rem;
  font-weight: 800;
  color: #ffffff;
  text-shadow: 0 0 40px rgba(0,212,255,0.3);
  margin-bottom: 10px;
  letter-spacing: -1px;
}
.hero-content .slogan {
  font-size: 1.4rem;
  color: var(--accent);
  margin-bottom: 15px;
  letter-spacing: 3px;
  text-transform: uppercase;
}
.hero-content .subtitle {
  font-size: 1.1rem;
  color: #9999bb;
  margin-bottom: 35px;
}

/* Buttons */
.btn-primary-dark {
  background: var(--accent);
  color: #0a0a14;
  padding: 14px 35px;
  border-radius: 50px;
  font-weight: 700;
  text-decoration: none;
  display: inline-block;
  transition: all 0.3s;
  border: none;
  letter-spacing: 1px;
}
.btn-primary-dark:hover {
  background: #00e5ff;
  transform: translateY(-3px);
  box-shadow: 0 10px 30px rgba(0,212,255,0.3);
  color: #0a0a14;
}
.btn-outline-dark {
  border: 2px solid #444466;
  color: #ccccdd;
  padding: 14px 35px;
  border-radius: 50px;
  font-weight: 600;
  text-decoration: none;
  display: inline-block;
  transition: all 0.3s;
  letter-spacing: 1px;
}
.btn-outline-dark:hover {
  border-color: var(--accent);
  color: var(--accent);
  transform: translateY(-3px);
}

/* Section */
.section { padding: 70px 0; }
.section-alt { background: #0d0d1f; }
.section-title h2 {
  font-size: 2rem;
  font-weight: 700;
  color: #ffffff;
  text-align: center;
  margin-bottom: 15px;
}
.section-title p {
  color: var(--text-muted);
  text-align: center;
}

/* Slider Dots */
.slider-dots {
  position: absolute;
  bottom: 25px;
  left: 50%;
  transform: translateX(-50%);
  z-index: 3;
  display: flex;
  gap: 12px;
}
.slider-dot {
  width: 10px; height: 10px;
  border-radius: 50%;
  background: rgba(255,255,255,0.3);
  cursor: pointer;
  transition: all 0.3s;
  border: 2px solid transparent;
}
.slider-dot.active {
  background: var(--accent);
  border-color: var(--accent);
  box-shadow: 0 0 10px rgba(0,212,255,0.5);
}

/* Product Cards */
.card-dark {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 16px;
  overflow: hidden;
  transition: all 0.3s;
  cursor: pointer;
  height: 100%;
}
.card-dark:hover {
  background: var(--bg-card-hover);
  border-color: #3a3a6a;
  transform: translateY(-5px);
  box-shadow: 0 15px 40px rgba(0,0,0,0.4);
}
.card-dark img {
  width: 100%;
  height: 220px;
  object-fit: cover;
  filter: brightness(0.8);
}
.card-dark .card-body { padding: 18px; }
.card-dark .card-title { color: #ffffff; font-weight: 600; margin-bottom: 8px; font-size: 1rem; }
.card-dark .card-price { color: var(--accent); font-weight: 700; font-size: 1.2rem; }
.card-dark .card-category { color: var(--text-muted); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 1px; }

/* Category Cards */
.category-card-dark {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 16px;
  padding: 35px 20px;
  text-align: center;
  transition: all 0.3s;
  text-decoration: none;
  display: block;
}
.category-card-dark:hover {
  background: #1e1e40;
  border-color: var(--accent);
  transform: translateY(-5px);
}
.category-card-dark i { font-size: 2.5rem; color: var(--accent); margin-bottom: 15px; }
.category-card-dark h5 { color: #ffffff; margin-bottom: 5px; }
.category-card-dark p { color: var(--text-muted); margin: 0; font-size: 0.9rem; }

/* Tech Icon Cards */
.tech-icon-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 15px;
  padding: 25px 15px;
  transition: all 0.3s;
  text-align: center;
}
.tech-icon-card:hover {
  transform: translateY(-8px);
  border-color: var(--accent) !important;
  box-shadow: 0 15px 40px rgba(0,212,255,0.15);
  cursor: pointer;
}

/* Stat Counter */
.stat-counter i { transition: transform 0.3s; }
.stat-counter:hover i { transform: scale(1.2); }

/* Step Cards */
.step-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 20px;
  padding: 30px;
  text-align: center;
  position: relative;
  transition: all 0.3s;
}
.step-card:hover { border-color: var(--accent); transform: translateY(-5px); }
.step-number {
  position: absolute;
  top: -20px;
  left: 50%;
  transform: translateX(-50%);
  width: 40px;
  height: 40px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #0a0a14;
  font-weight: 800;
}

/* CuePay & Discord Sections */
.cuepay-section {
  background: linear-gradient(135deg, #0a1628 0%, #0f1f3a 100%);
  border-top: 1px solid #1a3355;
  border-bottom: 1px solid #1a3355;
}
.discord-section {
  background: linear-gradient(135deg, #1a1a3e 0%, #252550 100%);
  border-top: 1px solid #333366;
}

/* Badge */
.badge-dark {
  padding: 5px 14px;
  border-radius: 20px;
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 1px;
  display: inline-block;
}
.badge-completed { background: rgba(16,185,129,0.2); color: #10b981; border: 1px solid rgba(16,185,129,0.3); }
.badge-progress { background: rgba(245,158,11,0.2); color: #f59e0b; border: 1px solid rgba(245,158,11,0.3); }

@media (max-width: 768px) {
  .hero-slideshow { height: 400px; }
  .hero-content h1 { font-size: 2.2rem; }
  .hero-content .slogan { font-size: 1rem; }
  .section { padding: 40px 0; }
}
</style>
</head>
